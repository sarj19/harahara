# Telegram Bot Configuration
# Copy this file to .env and fill in your values.
# The bot loads .env automatically on startup.

# Required: Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Required: Your numeric Telegram user ID (send /start to @userinfobot)
TELEGRAM_AUTHORIZED_USER_ID=YOUR_USER_ID_HERE

# Optional: Override default paths (defaults are relative to project root)
# BOT_LOG_FILE=/path/to/logs/harahara_bot.log
# BOT_YAML_PATH=/path/to/bot_commands.yaml
# BOT_PERSONAL_YAML_PATH=/path/to/personal/bot_commands.yaml
# BOT_UNAUTHORIZED_ID_FILE=/path/to/logs/latest_unauthorized_id.txt

# Optional: launchd service name (used by /restartbot)
# BOT_LAUNCHD_SERVICE=com.harahara.telegrambot

# Optional: Directory containing personal scripts (antigravity.sh, etc.)
# BOT_SCRIPTS_DIR=/path/to/personal

# Optional: Heartbeat interval in hours (default: 1).
# Send a fish emoji (🐟) to the user periodically to show the bot is still alive.
# Set to 0 to disable message heartbeats.
# BOT_HEARTBEAT_INTERVAL=1

# Optional: NLP mode (default: false).
# When enabled, plain text messages (without /) are forwarded to the Gemini CLI.
# Commands starting with / are always handled directly — no AI tokens burned.
# BOT_NLP_ENABLED=false
# BOT_NLP_CONTEXT_SIZE=20

# Optional: AI backend — "gemini" (cloud, default) or "ollama" (local, free).
# Run /ollamasetup to install and configure Ollama.
# BOT_AI_BACKEND=gemini
# BOT_OLLAMA_MODEL=llama3.2:1b

# Optional: Bot identity (personalize your bot's name and emoji)
# These appear in heartbeats, startup messages, /help, and /status.
# BOT_NAME=harahara
# BOT_EMOJI=🐟

# Optional: Custom welcome & status messages
# BOT_GREETING — overrides the time-based greeting on startup (e.g. "Rise and grind!")
# BOT_STATUS_TAGLINE — shown at the bottom of /status (e.g. "Silently watching the riverbed...")
# BOT_GREETING=
# BOT_STATUS_TAGLINE=

# Optional: Custom macOS voice for /say (run /voices to list available voices)
# BOT_VOICE=Samantha

# Optional: Daily activity digest time in 24h format (empty = disabled)
# Sends a summary of commands run, screenshots taken, and uptime.
# BOT_DIGEST_TIME=21:00

# Optional: Scheduled commands YAML path (default: personal/schedules.yaml)
# BOT_SCHEDULES_PATH=

# Optional: Quick reply keyboard commands (comma-separated, shown by /keyboard)
# BOT_KEYBOARD_COMMANDS=ping,screenshot,volume,status,help

# --- File Transfer & Notes ---
# BOT_DOWNLOADS_DIR=~/Downloads/harahara
# BOT_NOTES_FILE=./personal/notes.json
# BOT_NOTES_BACKEND=local  # local | apple | google
# BOT_MACROS_PATH=./personal/macros.yaml

# --- Google Calendar & Gmail (optional) ---
# Download OAuth2 credentials from Google Cloud Console, save as:
# BOT_GOOGLE_CREDENTIALS=./personal/google_credentials.json
# BOT_GOOGLE_TOKEN=./personal/google_token.json
